{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "devhealthrg-westus2",
      "metadata": {
        "_parameterType": "resourceGroup",
        "description": "Nome do grupo de recursos do recurso. É recomendável colocar os recursos no mesmo grupo de recursos para melhor acompanhamento."
      }
    },
    "resourceGroupLocation": {
      "type": "string",
      "defaultValue": "westus2",
      "metadata": {
        "_parameterType": "location",
        "description": "Local do grupo de recursos. Os grupos de recursos podem ter um local diferente do local dos recursos."
      }
    },
    "resourceLocation": {
      "type": "string",
      "defaultValue": "[parameters('resourceGroupLocation')]",
      "metadata": {
        "_parameterType": "location",
        "description": "Local do recurso. Por padrão, use o local do grupo de recursos, a menos que não haja suporte para o provedor de recursos."
      }
    },
    "tenantId": {
      "type": "string",
      "defaultValue": "a5d1b3e9-0eec-4028-9a6e-ee15cb02f6a2",
      "metadata": {
        "_parameterType": "tenantId",
        "description": "ID do locatário do recurso."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "name": "[parameters('resourceGroupName')]",
      "location": "[parameters('resourceGroupLocation')]",
      "apiVersion": "2019-10-01"
    },
    {
      "type": "Microsoft.Resources/deployments",
      "name": "[concat(parameters('resourceGroupName'), 'Deployment', uniqueString(concat('integracaovindi', subscription().subscriptionId)))]",
      "resourceGroup": "[parameters('resourceGroupName')]",
      "apiVersion": "2019-10-01",
      "dependsOn": [
        "[parameters('resourceGroupName')]"
      ],
      "properties": {
        "mode": "Incremental",
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "resources": [
            {
              "name": "integracaovindi",
              "type": "Microsoft.KeyVault/vaults",
              "location": "[parameters('resourceLocation')]",
              "properties": {
                "sku": {
                  "family": "A",
                  "name": "Standard"
                },
                "tenantId": "[parameters('tenantId')]",
                "networkAcls": {
                  "bypass": "None",
                  "defaultAction": "Allow",
                  "ipRules": [],
                  "virtualNetworkRules": []
                },
                "accessPolicies": [],
                "enabledForDeployment": false,
                "enabledForDiskEncryption": false,
                "enabledForTemplateDeployment": false,
                "enableSoftDelete": true,
                "softDeleteRetentionInDays": 90,
                "enableRbacAuthorization": false
              },
              "apiVersion": "2016-10-01"
            }
          ]
        }
      }
    }
  ],
  "metadata": {
    "_dependencyType": "secrets.keyVault"
  }
}